# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:pass@neon-host/manabogo
REDIS_URL=redis://localhost:6379/0

# ── Auth (Backend) ────────────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production-minimum-32-characters
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Email ─────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.xxxx
EMAIL_FROM=noreply@manabogo.app
EMAIL_FROM_NAME=ManaboGo

# ── AWS ───────────────────────────────────────────────────────
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
ECS_CLUSTER=manabogo-cluster
ECS_SERVICE_API=manabogo-api
AMPLIFY_APP_ID=

# ── Cloudflare R2 ─────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=manabogo-assets
R2_PUBLIC_URL=https://assets.manabogo.app

# ── Payments (Phase 8) ────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ── Next.js Frontend ──────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_ENV=development
NEXTAUTH_SECRET=change-me-32-chars
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── next-intl ─────────────────────────────────────────────────
NEXT_PUBLIC_DEFAULT_LOCALE=en

# ── Optional: Disposable email denylist path ──────────────────
# DENYLIST_PATH=/path/to/disposable_domains.txt
